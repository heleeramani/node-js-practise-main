<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit</title>
  </head>
  <body>
    <h3>Edit Your Message</h3>
    <p>Edit your chat: <%= chat._id %></p>
    <p>This chat was sent from: <b><%= chat.from %></b> to <%= chat.to %> </p>
    <form action="/chats/<%= chat._id %>?_method=PUT" method="POST">
      <textarea name="msg" placeholder="Edit Your Message">
        <%= chat.msg %>
      </textarea>

      <button type="submit">Edit</button>
    </form>
  </body>
</html>