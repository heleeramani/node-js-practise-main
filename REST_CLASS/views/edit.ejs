<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit</title>
  </head>
  <body>
    <h1>Edit</h1>

    <p>Post Id: <%= post.id %></p>
    <p>Post Name: <%= post.name %></p>

    <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
      <textarea id="" name="content"><%= post.content %></textarea>
      <button type="Submit">Submit</button>
    </form>
  </body>
</html>
